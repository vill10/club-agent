# Anthropic — funds the deployed agent (separate from any Claude subscription)
ANTHROPIC_API_KEY=
# Web search
TAVILY_API_KEY=
# Google Places (New) — Text Search
GOOGLE_PLACES_API_KEY=
# 2GIS Catalog API (demo key ok for MVP)
TWOGIS_API_KEY=
# Cloudflare Turnstile (bot gate). Site key is public (client), secret is server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Local dev only: set true to bypass Turnstile verification when developing
TURNSTILE_DEV_BYPASS=false
# Cost + abuse caps
DAILY_BUDGET_USD=3
PER_IP_RUNS_PER_HOUR=3
PER_IP_RUNS_PER_DAY=8
# 32-byte random hex; rotates the daily IP hash salt
IP_HASH_DAILY_SALT=
# Kill switch — set true to disable new runs (existing run pages still render)
APP_DISABLED=false
# SQLite file location (local dev can use ./dev.sqlite)
DATABASE_PATH=./dev.sqlite
